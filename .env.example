# ===========================================
# GastroPOS - Variables de Entorno
# ===========================================
# Copia este archivo como .env y completa los valores
# con los datos de tu proyecto en https://supabase.com
# ===========================================

# ── SUPABASE (OBLIGATORIO PARA MULTI-DISPOSITIVO) ──
# Encontrarás estos valores en:
# Supabase Dashboard → Tu Proyecto → Settings → API

VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...TU_ANON_KEY_AQUI

# ── APP CONFIG (OPCIONAL) ──
VITE_APP_NAME=GastroPOS
VITE_APP_VERSION=1.0.0

# ── INSTRUCCIONES DE CONFIGURACIÓN ──
# 1. Crea un proyecto en https://supabase.com
# 2. Ve a Settings → API
# 3. Copia la "Project URL" en VITE_SUPABASE_URL
# 4. Copia la "anon / public" key en VITE_SUPABASE_ANON_KEY
# 5. Renombra este archivo de .env.example a .env
# 6. Ejecuta el SQL de /database.sql en el SQL Editor de Supabase
# 7. ¡Listo! El sistema se conectará automáticamente
